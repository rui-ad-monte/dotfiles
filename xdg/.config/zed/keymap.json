[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j j": "vim::NormalBefore",
      "ctrl-k": "editor::ShowSignatureHelp",
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",

      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
      "[ b": "pane::ActivatePreviousItem",
      "] b": "pane::ActivateNextItem",

      "g d": "editor::GoToDefinition",
      "g r": "editor::FindAllReferences",
      "g r r": "editor::FindAllReferences",
      "g r n": "editor::Rename",
      "g r i": "editor::GoToImplementation",
      "g r a": "editor::ToggleCodeActions",
      "g shift-i": "editor::GoToImplementation",
      "g y": "editor::GoToTypeDefinition",
      "g shift-d": "editor::GoToDeclaration",
      "shift-k": "editor::Hover",
      "g shift-k": "editor::ShowSignatureHelp",
      "] ]": "editor::GoToNextReference",
      "[ [": "editor::GoToPreviousReference",
      "alt-n": "editor::GoToNextReference",
      "alt-p": "editor::GoToPreviousReference",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",

      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",

      "space": null,
      "space space": "tab_switcher::ToggleAll",
      "space ,": "tab_switcher::ToggleAll",
      "space /": "pane::DeploySearch",
      "space `": "pane::AlternateFile",
      "space -": "pane::SplitDown",
      "space |": "pane::SplitRight",

      "space b b": "tab_switcher::ToggleAll",
      "space b d": "pane::CloseActiveItem",
      "space b shift-d": "pane::CloseActiveItem",
      "space b l": "pane::CloseItemsToTheLeft",
      "space b o": "pane::CloseOtherItems",
      "space b p": "pane::TogglePinTab",
      "space b r": "pane::CloseItemsToTheRight",

      "space c a": "editor::ToggleCodeActions",
      "space c shift-a": "editor::ToggleCodeActions",
      // Zed stable v1.0.1 does not include this action yet.
      "space c c": "editor::ToggleCodeLens",
      "space c shift-c": "editor::ToggleCodeLens",
      "space c d": "editor::Hover",
      "space c f": "editor::Format",
      "space c l": "lsp_tool::ToggleMenu",
      "space c o": "editor::OrganizeImports",
      "space c r": "editor::Rename",
      "space c s": "outline::Toggle",
      "space c shift-s": "editor::FindAllReferences",

      "space e": "project_panel::ToggleFocus",
      "space shift-e": "project_panel::ToggleFocus",
      "space f e": "project_panel::ToggleFocus",
      "space f shift-e": "project_panel::ToggleFocus",
      "space f f": "file_finder::Toggle",
      "space f shift-f": "file_finder::Toggle",
      "space f g": "file_finder::Toggle",
      "space f n": "workspace::NewFile",
      "space f p": ["projects::OpenRecent", { "create_new_window": false }],
      "space f r": ["projects::OpenRecent", { "create_new_window": false }],
      "space f t": "terminal_panel::ToggleFocus",
      "space f shift-t": "workspace::NewTerminal",

      "space g b": "editor::BlameHover",
      "space g d": "git::Diff",
      "space g shift-d": "git::BranchDiff",
      "space g h b": "editor::BlameHover",
      "space g h p": "editor::ToggleSelectedDiffHunks",
      "space g h r": "git::Restore",
      "space g h s": "git::ToggleStaged",
      "space g h u": "git::UnstageAndNext",
      "space g s": "git_panel::ToggleFocus",

      "space q q": "zed::Quit",

      "space s c": "command_palette::Toggle",
      "space s shift-c": "command_palette::Toggle",
      "space s d": "diagnostics::Deploy",
      "space s shift-d": "diagnostics::DeployCurrentFile",
      "space s g": "pane::DeploySearch",
      "space s shift-g": "pane::DeploySearch",
      "space s k": "zed::OpenKeymap",
      "space s r": ["pane::DeploySearch", { "replace_enabled": true }],
      "space s s": "outline::Toggle",
      "space s shift-s": "project_symbols::Toggle",

      "space tab [": "pane::ActivatePreviousItem",
      "space tab ]": "pane::ActivateNextItem",
      "space tab d": "pane::CloseActiveItem",
      "space tab f": ["pane::ActivateItem", 0],
      "space tab l": "pane::ActivateLastItem",
      "space tab o": "pane::CloseOtherItems",
      "space tab tab": "workspace::NewFile",

      "space u b": "theme::ToggleMode",
      "space u shift-c": "theme_selector::Toggle",
      "space u d": "editor::ToggleDiagnostics",
      "space u g": "editor::ToggleIndentGuides",
      "space u h": "editor::ToggleInlayHints",
      "space u l": "editor::ToggleLineNumbers",
      "space u shift-l": "editor::ToggleRelativeLineNumbers",
      "space u w": "editor::ToggleSoftWrap",
      "space u z": "workspace::ToggleCenteredLayout",
      "space u shift-z": "workspace::ToggleZoom",

      "space w d": "pane::CloseActiveItem",
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",
      "space w m": "workspace::ToggleZoom",
      "space w q": "pane::CloseActiveItem",
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",

      "space x l": "diagnostics::DeployCurrentFile",
      "space x q": "diagnostics::Deploy",
      "space x shift-q": "diagnostics::Deploy",
      "space x x": "diagnostics::Deploy",
      "space x shift-x": "diagnostics::DeployCurrentFile",
    },
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward",

      "space": null,
      "space /": "pane::DeploySearch",
      "space c a": "editor::ToggleCodeActions",
      "space c f": "editor::FormatSelections",
      "space g h p": "editor::ToggleSelectedDiffHunks",
      "space s g": "pane::DeploySearch",
      "space s r": ["pane::DeploySearch", { "replace_enabled": true }],
    },
  },
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "terminal_panel::ToggleFocus",
      "ctrl-_": "terminal_panel::ToggleFocus",
    },
  },
]
